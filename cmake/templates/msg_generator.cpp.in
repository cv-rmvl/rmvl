}

template <typename Tp>
Tp read_scalar(const char *&src) noexcept {
    Tp value{};
    std::memcpy(&value, src, sizeof(Tp));
    src += sizeof(Tp);
    return value;
}

template <typename Tp>
void read_array(const char *&src, Tp *data, std::size_t count) noexcept {
    const auto size = count * sizeof(Tp);
    if (size != 0)
        std::memcpy(data, src, size);
    src += size;
}

